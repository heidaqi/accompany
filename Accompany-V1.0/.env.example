# ============================================
# Accompany 配置文件模板
# 复制此文件为 .env 并填入你的 API Key
# ============================================

# --- 第一级：主力LLM（推荐：火山方舟豆包）---
LLM_PRIMARY_PROVIDER=volcano
LLM_PRIMARY_MODEL=doubao-pro-32k
LLM_PRIMARY_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_PRIMARY_API_KEY=your_volcano_api_key_here

# --- 第二级：备选LLM ---
LLM_FALLBACK1_PROVIDER=deepseek
LLM_FALLBACK1_MODEL=deepseek-chat
LLM_FALLBACK1_BASE_URL=https://api.deepseek.com/v1
LLM_FALLBACK1_API_KEY=your_deepseek_api_key_here

# --- 第三级：兜底LLM ---
LLM_FALLBACK2_PROVIDER=qwen
LLM_FALLBACK2_MODEL=qwen-turbo
LLM_FALLBACK2_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_FALLBACK2_API_KEY=your_qwen_api_key_here

# --- Embedding 模型（ChromaDB 内置 ONNXMiniLM_L6_V2，无需额外配置）---
EMBEDDING_MODE=local

# --- 摄像头设置 ---
CAMERA_ID=0
EMOTION_CHECK_INTERVAL=10

# --- 功能开关 ---
ENABLE_PASSIVE_MONITORING=true
ENABLE_LONG_TERM_MEMORY=true
ENABLE_EMOTION_TRACKING=true

# --- 记忆设置 ---
SHORT_TERM_WINDOW=20
SHORT_TERM_TTL=1800
LONG_TERM_RECALL_TOP_K=5
MEMORY_CURATOR_INTERVAL=1800

# --- 用户画像 ---
USER_AGE_GROUP=young
USER_NICKNAME=主人
AI_NAME=豆包
AI_PERSONALITY=warm
# AI_PERSONA_DESC 定义AI的完整人设描述（系统提示词第一句），
# 可以自由替换为你想创建的任何角色
# AI_PERSONA_DESC=你是豆包——从星海飘来的包子精灵，住在用户电脑右下角。紫色长发，青色发光眼睛，外表酷酷内在软萌。眼睛随情绪明暗变化。

# --- 界面设置 ---
FONT_SIZE=normal
THEME=light
SPRITES_DIR=sprites_vroid
COMPANION_WIDTH=220
COMPANION_HEIGHT=320
LANGUAGE=zh-CN
